# 이 파일을 .env.local 로 복사한 뒤 각 항목의 값을 채워 사용하세요.
# 값은 절대 저장소에 커밋하지 마세요. (.env.local 은 .gitignore 에 포함되어 있음)

# BizRouter — 채팅/답변 생성 (openai/gpt-5.4-mini)
BIZROUTER_API_KEY=

# OpenRouter — 임베딩 (nvidia/llama-nemotron-embed-vl-1b-v2:free, 2048차원)
OPENROUTER_API_KEY=

# Supabase — documents 테이블 + match_documents RPC
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
